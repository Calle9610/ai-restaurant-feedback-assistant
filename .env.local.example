# Supabase – hämta från Project Settings > API i Supabase-dashboarden
# ANON_KEY respekterar Row Level Security – använd den för all läsning
# (default i både lib/supabase.ts och agent/db.py).
# SERVICE_ROLE_KEY kringgår RLS helt – använd bara för skrivoperationer
# som medvetet behöver det (createServiceClient() / get_service_client()).
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic – hämta från console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
