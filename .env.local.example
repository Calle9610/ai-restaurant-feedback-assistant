# Supabase – hämta från Project Settings > API i Supabase-dashboarden
# ANON_KEY respekterar Row Level Security – använd den för all läsning
# (default i både lib/supabase.ts och agent/db.py).
# SERVICE_ROLE_KEY kringgår RLS helt – använd bara för skrivoperationer
# som medvetet behöver det (createServiceClient() / get_service_client()).
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic – hämta från console.anthropic.com
# Webbappens nyckel.
ANTHROPIC_API_KEY=sk-ant-...

# Agentens egen Anthropic-nyckel, separat från ANTHROPIC_API_KEY ovan
# (kostnadsattribution + oberoende rotation mellan webbapp och agent-backend).
# Instansieras explicit i agent/loop.py — SDK:ns automatiska upptäckt av
# ANTHROPIC_API_KEY används medvetet inte, den skulle tyst plocka fel nyckel.
# Får ALDRIG behövas i CI; alla tester i agent/ mockar Anthropic-klienten.
AGENT_ANTHROPIC_API_KEY=sk-ant-...

# Modell agenten kör. Default: Haiku för billig iteration under utveckling.
# Byt till en starkare modell (t.ex. claude-sonnet-5) inför demo/evals genom
# att sätta variabeln — läses i agent/loop.py, aldrig hårdkodad i koden.
# --model på CLI:t (python -m agent.run) overridear denna per körning.
AGENT_MODEL=claude-haiku-4-5-20251001

# Salesforce – Developer Edition-org, OAuth 2.0 Client Credentials Flow
# (server-till-server, ingen browser-redirect). Connected/External Client
# App: Client Credentials Flow aktiverat i appen OCH i dess policy, med en
# "Run As"-användare satt. Client ID/Secret hämtas från appens
# "Manage Consumer Details". Får ALDRIG behövas i CI; agent/salesforce_client.py
# mockas i alla tester.
SF_INSTANCE_URL=https://xxxxxxxxxxxxxxxxxxxx.my.salesforce.com
SF_CLIENT_ID=...
SF_CLIENT_SECRET=...
